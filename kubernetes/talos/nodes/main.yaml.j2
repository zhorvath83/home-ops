---
# Node-specific patch for the single control plane node `main` (192.168.1.11).
# Applied on top of machineconfig.yaml.j2 via `talosctl machineconfig patch`.
machine:
  type: controlplane
  network:
    hostname: main
  install:
    # PC801 NVMe (faster Gen4 capable disk, HP OEM variant of the SK hynix
    # Platinum P41 line) → Talos OS + etcd + EPHEMERAL volume.
    # The other NVMe (PC711, HP OEM variant of the SK hynix Gold P31) is left
    # unselected and gets claimed by the UserVolumeConfig in machineconfig.yaml.j2
    # for the democratic-csi local-hostpath data volume.
    disk: /dev/disk/by-id/nvme-PC801_NVMe_SK_hynix_1TB_SJBAN46291390A74W
