{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    ':enableRenovate',
    'config:recommended',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    ':automergePr',
    'docker:enableMajor',
    ':enablePreCommit',
    'helpers:pinGitHubActionDigestsToSemver',
    'github>home-operations/renovate-presets//managers/grafanaDashboards.json5#2.1.0',
    'github>zhorvath83/home-ops//.renovate/allowedVersions.json5',
    'github>zhorvath83/home-ops//.renovate/autoMerge.json5',
    'github>zhorvath83/home-ops//.renovate/customManagers.json5',
    'github>zhorvath83/home-ops//.renovate/disabledDatasources.json5',
    'github>zhorvath83/home-ops//.renovate/groups.json5',
    'github>zhorvath83/home-ops//.renovate/overrides.json5',
    'github>zhorvath83/home-ops//.renovate/prBodyNotes.json5',
    'github>zhorvath83/home-ops//.renovate/semanticCommits.json5',
    'github>zhorvath83/home-ops//.renovate/talosFactory.json5',
  ],
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  baseBranchPatterns: [
    'main',
  ],
  commitBodyTable: true,
  suppressNotifications: [
    'prIgnoreNotification',
    'prEditedNotification',
  ],
  rebaseWhen: 'auto',
  assignees: [
    '@zhorvath83',
  ],
  timezone: 'Europe/Budapest',
  registryAliases: {
    'mirror.gcr.io': 'docker.io',
  },
  flux: {
    managerFilePatterns: [
      '/^kubernetes/.+\\.yaml(?:\\.j2)?$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/^kubernetes/.+\\.yaml(?:\\.j2)?$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/^kubernetes/.+\\.yaml(?:\\.j2)?$/',
    ],
  },
  helmfile: {
    managerFilePatterns: [
      '/^kubernetes/bootstrap/helmfile\\.d/.+\\.yaml$/',
    ],
  },
}
