{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: "Process OCI dependencies in Kubernetes YAML",
      managerFilePatterns: [
        "/^kubernetes/.+\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        "oci://(?<depName>[^:\\s]+):(?<currentValue>\\S+)",
      ],
      datasourceTemplate: "docker",
    },
    {
      customType: "regex",
      description: "Process inline `# renovate: datasource=X depName=Y` annotations in YAML and mise.toml",
      managerFilePatterns: [
        "/^kubernetes/.+\\.yaml(?:\\.j2)?$/",
        "/(^|/)\\.?mise\\.toml$/",
      ],
      matchStrings: [
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\n.+?[\"'](?<currentValue>[^\"']+)[\"']",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
    {
      customType: "regex",
      description: "Process registry.k8s.io container images by tag",
      managerFilePatterns: [
        "/^kubernetes/.+\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        "registry\\.k8s\\.io/(?<depName>[^:\\s]+):(?<currentValue>v\\d+\\.\\d+\\.\\d+)",
      ],
      datasourceTemplate: "docker",
      packageNameTemplate: "registry.k8s.io/{{depName}}",
    },
    {
      customType: "regex",
      description: "Process Helm chart images that use the non-standard `image.registry: <full-path>` + `image.tag: <version>[@sha256:<digest>]` shape (e.g. democratic-csi)",
      managerFilePatterns: [
        "/^kubernetes/.+\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        // currentDigest includes the `sha256:` prefix so it matches the docker
        // datasource's newDigest format — otherwise confirmIfDepUpdated fails
        // with "Digest is not updated" and the branch update errors out.
        "registry:\\s+(?<depName>\\S+/\\S+)\\s+tag:\\s*[\"']?(?<currentValue>v?[0-9][^\"'\\s@]*)(?:@(?<currentDigest>sha256:[a-f0-9]{64}))?",
      ],
      datasourceTemplate: "docker",
    },
    {
      customType: "regex",
      description: "Process busybox image refs across bjw-s (repository/tag), democratic-csi (registry/tag), and CEL inline (image: \"path:tag\") shapes",
      managerFilePatterns: [
        "/^kubernetes/.+\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        "repository:\\s+public\\.ecr\\.aws/docker/library/busybox[\\s\\S]+?tag:\\s*[\"']?(?<currentValue>[^\"'\\s]+)",
        "registry:\\s+public\\.ecr\\.aws/docker/library/busybox[\\s\\S]+?tag:\\s*[\"']?(?<currentValue>[^\"'\\s]+)",
        "image:\\s*[\"']public\\.ecr\\.aws/docker/library/busybox:(?<currentValue>[^\"'\\s]+)[\"']",
      ],
      datasourceTemplate: "docker",
      depNameTemplate: "public.ecr.aws/docker/library/busybox",
    },
  ],
}
