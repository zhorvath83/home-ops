{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Loose versioning for non-semver image tags",
      matchDatasources: ["docker"],
      matchPackageNames: ["/plex/", "/qbittorrent/"],
      versioning: "loose",
    },
    {
      description: "Regex versioning for calibre-web-automated (V/v-prefixed)",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/crocodilestick/calibre-web-automated"],
      versioning: "regex:^[Vv](?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
    },
    {
      description: "Override helmfile dependency name so charts surface as their packageName",
      matchDatasources: ["docker"],
      matchManagers: ["helmfile"],
      overrideDepName: "{{packageName}}",
    },
    {
      description: "Separate minor and patch updates for Helm charts; skip deprecated chart versions",
      matchDatasources: ["helm"],
      separateMinorPatch: true,
      ignoreDeprecated: true,
    },
    {
      description: "Type label for major updates",
      matchUpdateTypes: ["major"],
      labels: ["type/major"],
    },
    {
      description: "Type label for minor updates",
      matchUpdateTypes: ["minor"],
      labels: ["type/minor"],
    },
    {
      description: "Type label for patch updates",
      matchUpdateTypes: ["patch"],
      labels: ["type/patch"],
    },
    {
      description: "Type label for digest updates",
      matchUpdateTypes: ["digest"],
      labels: ["type/digest"],
    },
    {
      description: "Label for container image updates",
      matchDatasources: ["docker"],
      addLabels: ["renovate/container"],
    },
    {
      description: "Label for Helm chart updates",
      matchDatasources: ["helm"],
      addLabels: ["renovate/helm"],
    },
    {
      description: "Label for GitHub Actions updates",
      matchManagers: ["github-actions"],
      addLabels: ["renovate/github-action"],
    },
    {
      description: "Label for GitHub Release updates",
      matchDatasources: ["github-releases", "github-tags"],
      addLabels: ["renovate/github-release"],
    },
    {
      description: "Override packageName for kubectl in mise (aqua 3-part path breaks github-tags owner/repo)",
      matchManagers: ["mise"],
      matchDepNames: ["kubectl"],
      overridePackageName: "kubernetes/kubernetes",
    },
  ],
}
