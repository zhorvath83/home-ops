{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  // automergeType: "pr" is set globally via the :automergePr preset in
  // .renovaterc.json5 — Renovate opens a PR, waits for required status checks
  // to pass, then merges. The rules below scope which packages are eligible.
  // Switched from "branch" to "pr" so future required CI checks gate the
  // automerge instead of being bypassed.
  packageRules: [
    {
      description: "Auto-merge trusted container updates (digest, minor, patch)",
      matchDatasources: ["docker"],
      automerge: true,
      matchUpdateTypes: ["digest", "minor", "patch"],
      matchPackagePrefixes: [
        "ghcr.io/home-operations",
        "ghcr.io/onedr0p",
        "ghcr.io/bjw-s",
      ],
    },
    {
      description: "Auto-merge coredns minor and patch updates",
      matchDatasources: ["docker"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
      matchPackagePrefixes: [
        "ghcr.io/coredns",
      ],
    },
    {
      description: "Auto-merge kube-prometheus-stack minor and patch updates",
      matchDatasources: ["docker", "helm"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["/kube-prometheus-stack/"],
    },
    {
      description: "Auto-merge pre-commit hook updates",
      matchManagers: ["pre-commit"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch", "digest"],
    },
    {
      description: "Auto-merge GitHub Actions minor/patch updates (3-day cooldown)",
      matchManagers: ["github-actions"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
      excludePackagePrefixes: ["actions/"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      // Effectively no cooldown; 1 minute is the minimum Renovate accepts.
      description: "Auto-merge trusted GitHub Actions fast-track",
      matchManagers: ["github-actions"],
      matchPackagePrefixes: ["actions/"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "1 minute",
      ignoreTests: true,
    },
  ],
}
