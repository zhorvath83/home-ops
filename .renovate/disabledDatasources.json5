{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Disable Flux controller image updates (managed declaratively by FluxInstance distribution)",
      matchPackageNames: [
        "ghcr.io/fluxcd/helm-controller",
        "ghcr.io/fluxcd/image-automation-controller",
        "ghcr.io/fluxcd/image-reflector-controller",
        "ghcr.io/fluxcd/kustomize-controller",
        "ghcr.io/fluxcd/notification-controller",
        "ghcr.io/fluxcd/source-controller",
      ],
      enabled: false,
    },
    {
      description: "Disable kubernetes-api datasource noise from the kubernetes manager",
      matchManagers: ["kubernetes"],
      matchDatasources: ["kubernetes-api"],
      enabled: false,
    },
  ],
}
